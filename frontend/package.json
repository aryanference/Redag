{
  "name": "redag-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "check:workflow-mapping": "node scripts/check-workflow-node-backend-mapping.mjs",
    "check:workflow-branch-routing": "node --experimental-strip-types scripts/check-workflow-branch-routing.mjs",
    "check:workflow-model-options": "node scripts/check-workflow-real-model-options.mjs",
    "check:workflow-knowledge-entry": "node scripts/check-workflow-knowledge-entry.mjs",
    "check:sidebar-motion": "node scripts/check-sidebar-motion.mjs",
    "check:knowledge-delete": "node scripts/check-knowledge-delete-action.mjs",
    "check:model-local-quota": "node scripts/check-model-local-quota.mjs",
    "check:model-local-runtime": "node scripts/check-model-local-runtime-availability.mjs",
    "check:copilot-actions": "node scripts/check-copilot-workflow-actions.mjs",
    "check:notifications": "node scripts/check-notify-stream-contract.mjs && node --experimental-strip-types scripts/check-notification-history-merge.mjs",
    "check:public-home": "node scripts/check-public-home-no-auth-redirect.mjs",
    "api:generate": "orval --config src/api/openapi/orval.config.ts",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vue-flow/background": "1.3.2",
    "@vue-flow/controls": "1.1.3",
    "@vue-flow/core": "1.48.2",
    "@vue-flow/minimap": "1.5.4",
    "axios": "^1.13.2",
    "lucide-vue-next": "1.0.0",
    "pinia": "3.0.4",
    "vue": "3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "5.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "6.0.7",
    "autoprefixer": "^10.4.22",
    "orval": "^8.13.0",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.19",
    "typescript": "^5.9.3",
    "vite": "8.0.14",
    "vue-tsc": "^3.1.5"
  }
}
