VITE_API_BASE=/api
VITE_WS_BASE=/ws
VITE_SSE_BASE=/sse
OPENAPI_BASE=http://localhost:8080
VITE_OPENAPI_BASE=http://localhost:8080
VITE_MOCK_FALLBACK=true
VITE_NOTIFY_WS_FALLBACK=true
VITE_API_TIMEOUT_MS=15000

# Docker demo safe-mode defaults. Override these for production-like runs.
# Main workflow demo defaults: Whisper and LLM run normally unless explicitly disabled.
ENABLE_WHISPER=true
ENABLE_LLM=true
WHISPER_MODEL=small
OLLAMA_BASE_URL=http://host.docker.internal:11434
WORKFLOW_OCR_MOCK=true
WORKFLOW_OCR_MOCK_TEXT=Demo safe OCR text for AetherFlow.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
