{
  "include": ["vite.config.ts", "tailwind.config.ts"],
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "strict": true
  }
}
