# AetherFlow final production-like demo environment.
DEPLOY_HOST=192.168.101.68
TZ=Asia/Shanghai

DB_HOST=mysql
DB_PORT=3306
DB_PUBLIC_PORT=3307
DB_NAME=aetherflow
DB_USERNAME=root
DB_PASSWORD=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=aetherflow
MYSQL_USERNAME=root
MYSQL_PASSWORD=mysql

NACOS_HOST=nacos
NACOS_PORT=8848
NACOS_ADDR=nacos:8848
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=change-me-nacos-strong-password
NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567890123456789
NACOS_AUTH_TOKEN_EXPIRE_SECONDS=18000
NACOS_AUTH_IDENTITY_KEY=nacos
NACOS_AUTH_IDENTITY_VALUE=change-me-server-identity-value

SEATA_HOST=seata
SEATA_PORT=8091
SEATA_ADDR=seata:8091
SEATA_TX_GROUP=aetherflow_tx_group

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=aetherflow

MQ_HOST=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=aetherflow
RABBITMQ_PASSWORD=aetherflow
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_MANAGEMENT_USERNAME=aetherflow
RABBITMQ_MANAGEMENT_PASSWORD=aetherflow

MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://192.168.101.68:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aetherflow

# Elasticsearch
ELASTIC_PASSWORD=change-me-elastic-strong-password

AI_RUNTIME_HOST=python-ai-service
PYTHON_AI_BASE_URL=http://python-ai-service:8200
PYTHON_AI_CONNECT_TIMEOUT_MILLIS=3000
PYTHON_AI_READ_TIMEOUT_MILLIS=120000
ENABLE_WHISPER=true
ENABLE_LLM=true
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
FFMPEG_TIMEOUT_SECONDS=120
FILE_URL_REWRITE_FROM=http://localhost:9000
FILE_URL_REWRITE_TO=http://minio:9000

OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_DEFAULT_PROVIDER=OLLAMA
AI_DEFAULT_MODEL=qwen3:8b
WORKFLOW_EMBEDDING_MODEL=nomic-embed-text

SENTINEL_DASHBOARD=sentinel-dashboard:8858
JWT_SECRET=aetherflow-dev-secret-key-change-me-32bytes-minimum
JWT_REFRESH_SECRET=aetherflow-refresh-secret-change-me-32bytes-minimum
FILE_INTERNAL_TOKEN=aetherflow-file-internal-dev-token
FRONTEND_BASE_URL=http://192.168.101.68
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://192.168.101.68/api/auth/oauth/github/callback
GITHUB_OAUTH_SUCCESS_PATH=/auth/oauth/callback
GITHUB_OAUTH_FAILURE_PATH=/login
GITHUB_OAUTH_STATE_SECRET=aetherflow-github-oauth-state-secret-32bytes

NGINX_HTTP_PORT=80
VITE_API_BASE=/api
VITE_WS_BASE=/ws
VITE_SSE_BASE=/sse
VITE_MOCK_FALLBACK=false
VITE_NOTIFY_WS_FALLBACK=false
VITE_API_TIMEOUT_MS=15000

WORKFLOW_OCR_MOCK=true
WORKFLOW_OCR_PROVIDER=mock
WORKFLOW_OCR_MOCK_TEXT=Demo safe OCR text for AetherFlow.
WORKFLOW_RUNTIME_EVENT_MQ_ENABLED=false
WORKFLOW_RUNTIME_LOCK_ENABLED=true

TASK_QUEUE_PROTECTION_ENABLED=true
TASK_QUEUE_BUSY_DEPTH_THRESHOLD=1000
TASK_QUEUE_RECOVERY_DEPTH_THRESHOLD=300
TASK_CONSUMER_DEAD_LETTER_ENABLED=true
TASK_CONSUMER_DISPATCH_ENABLED=true
